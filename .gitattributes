# 统一文本文件自动规范化
* text=auto

# Linux / WSL 脚本必须使用 LF
*.sh text eol=lf

# Makefile 必须使用 LF
Makefile text eol=lf

# C/C++ 源码与配置建议统一 LF，避免跨平台混乱
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.cxx text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.hh text eol=lf
*.inl text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Web 前端与文档统一 LF
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf

# SQL 脚本统一 LF，避免导入和终端处理出现编码/换行问题
*.sql text eol=lf

# Windows 批处理保留 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
