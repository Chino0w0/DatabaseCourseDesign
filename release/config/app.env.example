# 社区健康档案管理系统 - Windows 发布包环境配置模板
# 使用方式：
# 1. 复制本文件为 app.env
# 2. 按你的 MySQL 实际信息修改下面参数
# 3. 再执行发布包中的启动脚本

# 数据库地址
# 如果 MySQL 运行在本机 Docker 容器，并映射到了宿主机 3306，通常仍可写 127.0.0.1
DB_HOST=127.0.0.1
DB_PORT=3306

# 数据库账号信息
DB_USER=ch_admin
DB_PASS=请填写你自己的数据库密码
DB_NAME=community_health

# 后端服务端口
PORT=8080

# 说明：
# - 如果数据库不在当前机器，请把 DB_HOST 改成目标机器 IP
# - 如果 Docker 端口映射不是 3306，请同步修改 DB_PORT
# - DB_PASS 没有安全默认值，必须按实际环境填写
# - 如果你修改了数据库名/账号/密码，这里也要对应修改
